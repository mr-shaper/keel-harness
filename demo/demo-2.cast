[0.003, "o", "═══════════════════════════════════════════════════════════════════\r\n  Demo 2 — 4-Layer Nested Parallel (Gap 3: P9 role drift)\r\n═══════════════════════════════════════════════════════════════════\r\n"]
[1.505, "o", "\r\n## The Topology\r\n"]
